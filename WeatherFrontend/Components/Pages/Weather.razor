@page "/weather"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Temperatura por Cidade</PageTitle>

<div class="container mt-4" style="max-width:600px">
    <h1 class="mb-4">🌤️ Temperatura Atual</h1>

    <div class="input-group mb-3">
        <input class="form-control form-control-lg"
               placeholder="Digite o nome da cidade..."
               @bind="cityInput"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
        <button class="btn btn-primary" @onclick="SearchWeather" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Buscar
        </button>
    </div>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (weather is not null)
    {
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <h3 class="card-title">@weather.City — @weather.Country</h3>
                <p class="text-muted mb-1">Lat: @weather.Latitude.ToString("F4") | Lon: @weather.Longitude.ToString("F4")</p>
                <hr />
                <div class="row justify-content-center">
                    <div class="col-5">
                        <div class="display-4 fw-bold text-danger">@weather.TemperatureCelsius °C</div>
                        <p class="text-muted">Celsius</p>
                    </div>
                    <div class="col-5">
                        <div class="display-4 fw-bold text-warning">@weather.TemperatureFahrenheit °F</div>
                        <p class="text-muted">Fahrenheit</p>
                    </div>
                </div>
                <p class="text-muted mt-2">
                    <small>Atualizado em: @weather.LastUpdated</small>
                </p>
            </div>
        </div>
    }
</div>

@code {
    private string cityInput = string.Empty;
    private WeatherResponse? weather;
    private string? errorMessage;
    private bool isLoading;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchWeather();
    }

    private async Task SearchWeather()
    {
        if (string.IsNullOrWhiteSpace(cityInput)) return;

        isLoading = true;
        errorMessage = null;
        weather = null;

        try
        {
            var http = HttpClientFactory.CreateClient("WeatherApi");
            var response = await http.GetAsync($"api/weather?city={Uri.EscapeDataString(cityInput)}");

            if (response.IsSuccessStatusCode)
            {
                weather = await response.Content.ReadFromJsonAsync<WeatherResponse>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = $"Cidade \"{cityInput}\" não encontrada. Verifique o nome e tente novamente.";
            }
            else
            {
                errorMessage = "Erro ao consultar a API. Tente novamente mais tarde.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro de conexão com a API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private record WeatherResponse(
        string City,
        string Country,
        double Latitude,
        double Longitude,
        double TemperatureCelsius,
        double TemperatureFahrenheit,
        string LastUpdated
    );
}
